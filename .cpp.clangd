CompileFlags:
  Add:
    - --target=x86_64-w64-windows-gnu
    - -fno-ms-extensions
    - -fno-delayed-template-parsing

    If:
      PathMatch: .*\.cpp
      Add:
        - -std=c++17
    If:
      PathMatch: .*\.c
      Add:
        - -std=c11
        - -x c

  Remove:
    - -W*

Index:
  Background: Build

